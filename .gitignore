.claude

# Python
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv/

# Secrets — NEVER commit
.env
.env.local
*.pem
*.key

# SQLite data — the runtime data/ dir at repo root holds the SQLite DB,
# heartbeats, pid files, etc. Anchor with a leading slash so this pattern
# does NOT also match src/jay_trading/data/, which is source code.
*.db
*.db-journal
*.db-wal
*.db-shm
/data/

# Logs
logs/
*.log

# Test / tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
coverage.xml

# VCR cassettes — we commit the curated ones, ignore scratch
tests/cassettes/scratch/

# Editor / OS
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db
